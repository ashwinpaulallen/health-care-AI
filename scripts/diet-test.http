  "userId": "test-user-001",
  "name": "7-Day Quick Start",
  "description": "One week balanced diet to kickstart healthy eating",
  "startDate": "2025-01-20",
  "durationDays": 7,
  "dailyMacroTargets": {
    "calories": 2000,
    "protein": 140,
    "carbs": 200,
    "fat": 70,
    "fiber": 28
