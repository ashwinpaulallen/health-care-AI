# LM Studio Configuration
LLM_BASE_URL=http://localhost:1234/v1
LLM_CHAT_MODEL=openai/gpt-oss-20b
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Database Configuration
MONGO_URI=mongodb://localhost:27017/diet-coach-poc

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Logging
LOG_LEVEL=info

# Optional: RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Optional: Cache TTL (seconds)
CACHE_TTL=3600

# Diet Tracking Configuration
# Number of days for rolling window summary (default: 7)
ROLLING_WINDOW_DAYS=7

# Conversation Context Configuration
# Enable multi-turn conversation context (default: true)
CONVERSATION_CONTEXT_ENABLED=true
# Number of recent messages to keep in full (default: 3)
# Higher values = more context but higher token usage
CONVERSATION_RECENT_MESSAGES=3
# Start summarizing after this many messages (default: 20)
# Tiered summarization: recent messages + mid-term + long-term summaries
# Reduces token usage for long conversations while maintaining context
CONVERSATION_SUMMARIZE_AFTER=20

# Tavily Search API (for internet search fallback)
# Get your API key from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

